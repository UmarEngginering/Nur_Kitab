    {
      "id": 1,
      "judul": "Maulid Simtutdurar (pembuka)",
      "tipe": "maulid",
      "bacaan": [
        "بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ",
        "اَلْحَمْدُ لِلّٰهِ الْقَوِيِّ سُلْطَانُهْ، الْوَاضِحِ بُرْهَانُهْ",
        "الْمَبْسُوْطِ فِي الْوُجُوْدِ كَرَمُهُ وَإِحْسَانُهْ"
      ]
    },
    {
      "id": 2,
      "judul": "Maulid Barzanji (Rawi 1)",
      "tipe": "maulid",
      "bacaan": [
        "اَبْتَدِئُ الْاِمْلَاءَ بِاسْمِ الذَّاتِ الْعَلِيَّةِ",
        "مُسْتَدِرًّا فَيْضَ الْبَرَكَاتِ عَلَى مَا اَنَالَهُ وَاَوْلَاهُ",
        "وَاُثَنِّيْ بِحَمْدٍ مَوَارِدُهُ سَاۤئِغَةٌ هَنِيَّةٌ",
        "مُمْتَطِيًا مِنَ الشُّكْرِ الْجَمِيْلِ مَطَايَاهُ",
        "وَاُصَلِّيْ وَاُسَلِّمُ عَلَى النُّوْرِ الْمَوْصُوْفِ بِالتَّقَدُّمِ وَالْاَوَّلِيَّةِ",
        "اَلْمُنْتَقِلِ فِى الْغُرَرِ الْكَرِيْمَةِ وَالْجِبَاهِ"
      ]
    }
  ]
